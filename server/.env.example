# ── DATABASE ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/mastertech_erp
PORT=3001

# ── AUTH ───────────────────────────────────────────────────────────────
JWT_SECRET=your-secure-random-secret-here

# ── FRONTEND URL (for CORS in production) ─────────────────────────────
FRONTEND_URL=https://your-frontend.railway.app

# ── SQUARE (Payments) ─────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_APPLICATION_ID=your-square-application-id
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_ENVIRONMENT=sandbox

# ── SQUARE TERMINAL (Physical Card Reader) ────────────────────────────
SQUARE_TERMINAL_DEVICE_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ── QUICKBOOKS (Invoice Sync) ─────────────────────────────────────────
# NOTE: Code references these as QB_* (not QUICKBOOKS_*)
QB_CLIENT_ID=your-qb-client-id
QB_CLIENT_SECRET=your-qb-client-secret
QB_ENVIRONMENT=sandbox
QB_REDIRECT_URI=https://your-backend.railway.app/api/quickbooks/callback

# ── EMAIL (Gmail SMTP) ────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Your Business Name <your-email@example.com>

# ── SMS (Twilio) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
